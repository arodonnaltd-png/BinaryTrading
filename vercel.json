{
  "buildCommand": "echo 'Static HTML app — no build step required'",
  "outputDirectory": ".",
  "cleanUrls": false,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1",
      "methods": ["GET", "POST", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/arome-binary-signal.html"
    }
  ]
}
